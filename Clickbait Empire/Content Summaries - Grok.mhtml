</span><span>                    [ -f </span><span style="color: rgb(152, 195, 121);">"</span><span style="color: rgb(209, 154, 102);">$chunk</span><span style="color: rgb(152, 195, 121);">"</span><span> ] || </span><span style="color: rgb(230, 192, 123);">continue</span><span>
