</span><span></span><span style="color: rgb(230, 192, 123);">readonly</span><span> MAIN_DIR=</span><span style="color: rgb(152, 195, 121);">"</span><span style="color: rgb(224, 108, 117);">$(pwd)</span><span style="color: rgb(152, 195, 121);">"</span><span>
</span><span></span><span style="color: rgb(230, 192, 123);">readonly</span><span> SKIP_FILE=</span><span style="color: rgb(152, 195, 121);">"overview.txt"</span><span>
</span>
<span></span><span style="color: rgb(92, 99, 112); font-style: italic;"># Function to check if a file is already processed</span><span>
