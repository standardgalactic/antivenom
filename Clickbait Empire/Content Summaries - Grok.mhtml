block; overflow-x: auto; padding: 16px; color: white; background: rgb(18, 19, 20); border-radius: 0px 0px 12px 12px; margin-top: 0px; font-size: 0.9em; font-family: var(--font-ibm-plex-mono); line-height: 1.5em;"><code style="white-space: pre; line-height: inherit; font-size: inherit;"><span style="color: rgb(97, 174, 238);">#!/bin/bash</span><span>
