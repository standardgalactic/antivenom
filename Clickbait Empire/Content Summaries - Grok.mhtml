</span><span>        [ -d </span><span style="color: rgb(152, 195, 121);">"</span><span style="color: rgb(209, 154, 102);">$dir</span><span style="color: rgb(152, 195, 121);">"</span><span> ] || </span><span style="color: rgb(230, 192, 123);">continue</span><span>
</span><span>        process_files </span><span style="color: rgb(152, 195, 121);">"</span><span style="color: rgb(209, 154, 102);">$dir</span><span style="color: rgb(152, 195, 121);">"</span><span>
</span><span>        process_subdirectories </span><span style="color: rgb(152, 195, 121);">"</span><span style="color: rgb(209, 154, 102);">$dir</span><span style="color: rgb(152, 195, 121);">"</span><span>
