</span><span>                    </span><span style="color: rgb(230, 192, 123);">echo</span><span> </span><span style="color: rgb(152, 195, 121);">"Summarizing chunk: </span><span style="color: rgb(209, 154, 102);">$chunk_name</span><span style="color: rgb(152, 195, 121);">"</span><span> &gt;&gt; </span><span style="color: rgb(152, 195, 121);">"</span><span style="color: rgb(209, 154, 102);">$MAIN_DIR</span><span style="color: rgb(152, 195, 121);">/</span><span style="color: rgb(209, 154, 102);">$PROGRESS_FILE</span><span style="color: rgb(152, 195, 121);">"</span><span>
