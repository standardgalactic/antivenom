<span></span><span style="color: rgb(92, 99, 112); font-style: italic;"># Function to process subdirectories recursively</span><span>
</span><span></span><span class="hljs-function" style="color: rgb(97, 174, 238);">process_subdirectories</span><span>() {
</span><span>    </span><span style="color: rgb(230, 192, 123);">local</span><span> parent_dir=</span><span style="color: rgb(152, 195, 121);">"</span><span style="color: rgb(209, 154, 102);">$1</span><span style="color: rgb(152, 195, 121);">"</span><span>
</span>    
<span>    </span><span style="color: rgb(198, 120, 221);">for</span><span> dir </span><span style="color: rgb(198, 120, 221);">in</span><span> </span><span style="color: rgb(152, 195, 121);">"</span><span style="color: rgb(209, 154, 102);">$parent_dir</span><span style="color: rgb(152, 195, 121);">"</span><span>/*/ ; </span><span style="color: rgb(198, 120, 221);">do</span><span>
